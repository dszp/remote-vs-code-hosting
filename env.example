# Fill in the __PLACEHOLDER__ tokens for your environment. Copy to .env (gitignored)
# OR, preferred, resolve secrets from 1Password at run time.
# Nothing here should hold a real secret in git — these are names + how to fill them.

# --- Phase 0: Proxmox VM (run against root@__PVE_HOST__) ---
VMID=__VMID__                    # any unused Proxmox VM ID
VM_NAME=__VM_NAME__
VM_CORES=4
VM_MEM_MB=8192
VM_DISK_GB=60
PVE_STORAGE=__PVE_STORAGE__      # Proxmox storage for the VM disk (zfspool or LVM-thin with space)
BRIDGE=__BRIDGE__                # Proxmox network bridge (e.g. vmbr0)
CI_USER=__DEV_USER__
# PUBKEY is your laptop public key cloud-init installs:
#   PUBKEY="$(cat ~/.ssh/id_ed25519.pub)"

# --- Phase 1: base ---
DEV_USER=__DEV_USER__

# --- Phase 2: Tailscale (optional non-interactive) ---
# TS_AUTHKEY resolved from 1Password, never committed:
#   TS_AUTHKEY="$(op read 'op://__OP_VAULT__/Tailscale/authkey')"

# --- Phase 3: Cloudflare ---
CF_TUNNEL_NAME=__VM_NAME__
CF_HOSTNAME=__SSH_HOSTNAME__
# Access service token (headless SSH), resolved from 1Password on the CLIENT:
#   export TUNNEL_SERVICE_TOKEN_ID="$(op read 'op://__OP_VAULT__/CF-Access-__VM_NAME__/client-id')"
#   export TUNNEL_SERVICE_TOKEN_SECRET="$(op read 'op://__OP_VAULT__/CF-Access-__VM_NAME__/client-secret')"

# --- Phase 5: Claude Code ---
NODE_VERSION=lts/*

# --- Phase 6: code-server (optional) ---
CODE_SERVER_PORT=8080
CF_HTTP_HOSTNAME=__CODE_HOSTNAME__
# CODE_SERVER_PASSWORD="$(op read --account __OP_ACCOUNT__ 'op://__OP_VAULT__/__CODE_SERVER_PW_ITEM__/password')"

# --- Optional: 1Password Service Account for RUNTIME op on the VM only ---
# Only if something on the VM must `op read` on its own. Scope to one vault, store 600.
#   OP_SERVICE_ACCOUNT_TOKEN="$(op read 'op://__OP_VAULT__/RVC-ServiceAccount/credential')"

# --- Optional: post-deploy enhancements (mac/ scripts + deploy/85-notify-hook.sh) ---
# All have sensible defaults; override only if you diverge from the names above.
AUTODEV_HOST=autodev           # silent VS Code Remote-SSH host alias (mac/autodev-key-setup.sh)
NOTIFY_SSH_HOST=autodev        # host used to build the click-to-open VS Code URL in notifications
# VM-side ~/.notify/push.env (not committed): NOTIFY_PUSH_MODE=off|always|fallback, plus
# PUSHOVER_TOKEN/PUSHOVER_USER or NTFY_URL. Resolve any token from 1Password at write time.
