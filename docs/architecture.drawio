    <mxCell id="title" value="Remote VS Code + Persistent Claude Code — how the setup fits together" style="text;html=1;align=center;fontSize=20;fontStyle=1;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="40" y="15" width="1500" height="36" as="geometry"/></mxCell>

    <mxCell id="z_clients" value="CLIENTS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontStyle=1;fontSize=15;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="40" y="70" width="300" height="680" as="geometry"/></mxCell>
    <mxCell id="z_transport" value="TRANSPORT  —  no public inbound port" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontStyle=1;fontSize=15;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="380" y="70" width="300" height="680" as="geometry"/></mxCell>
    <mxCell id="z_proxmox" value="PROXMOX host  ·  __PVE_HOST__  ·  Tailscale __PVE_TS_IP__  ·  CPU type: host" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F0F0;strokeColor=#666666;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontStyle=1;fontSize=15;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="720" y="70" width="840" height="690" as="geometry"/></mxCell>
    <mxCell id="vm_box" value="AlmaLinux 10 VM  ·  __VM_NAME__  ·  LAN __VM_LAN_IP__  ·  VMID __VMID__" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCFCFF;strokeColor=#333333;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontStyle=1;fontSize=13;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="745" y="145" width="690" height="590" as="geometry"/></mxCell>

    <mxCell id="c_laptop" value="macOS laptop  (primary)&#10;• Native VS Code — Remote-SSH&#10;• mosh (over Tailscale / UDP)&#10;• 1Password — TouchID&#10;   – op secret resolver&#10;   – SSH agent (keys stay on laptop)&#10;• Notify listener (socat + LaunchAgent)&#10;• autodev key — silent reconnect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="110" width="260" height="235" as="geometry"/></mxCell>
    <mxCell id="c_ipad" value="iPad&#10;• Browser code-server&#10;• Blink — mosh + code (URL actions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="365" width="260" height="95" as="geometry"/></mxCell>
    <mxCell id="c_iphone" value="iPhone&#10;• Pushover / ntfy push&#10;  (attention + reboot alerts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="485" width="260" height="80" as="geometry"/></mxCell>
    <mxCell id="c_win" value="Windows (basic access)&#10;• VS Code Remote-SSH&#10;• Tailscale + cloudflared&#10;  (no mosh / op / helpers)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="590" width="260" height="100" as="geometry"/></mxCell>

    <mxCell id="t_tail" value="Tailscale  (PRIMARY)&#10;WireGuard mesh · MagicDNS&#10;Carries UDP → mosh works natively&#10;No public port · laptop/iPad/Win on tailnet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="400" y="120" width="260" height="185" as="geometry"/></mxCell>
    <mxCell id="t_cf_zone" value="Cloudflare  (SECONDARY)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontStyle=1;fontSize=12;fontColor=#7A4B00;" vertex="1" parent="1"><mxGeometry x="400" y="345" width="260" height="395" as="geometry"/></mxCell>
    <mxCell id="t_cf_access" value="Access (Zero Trust)&#10;• GitHub IdP / email OTP&#10;• Service token (headless, deferred)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2E0;strokeColor=#D79B00;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="415" y="385" width="230" height="95" as="geometry"/></mxCell>
    <mxCell id="t_cf_tunnel" value="Tunnel&#10;cloudflared dials out :443 only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2E0;strokeColor=#D79B00;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="415" y="495" width="230" height="60" as="geometry"/></mxCell>
    <mxCell id="t_cf_hosts" value="Hostnames (__BASE_DOMAIN__ zone)&#10;• __SSH_HOSTNAME__ → SSH&#10;• __CODE_HOSTNAME__ → code-server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2E0;strokeColor=#D79B00;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="415" y="570" width="230" height="150" as="geometry"/></mxCell>

    <mxCell id="p_persist" value="PERSISTENCE  (load-bearing)&#10;loginctl enable-linger  +  tmux server (session 'claude')&#10;survives laptop-off &amp; disconnect  —  NOT reboot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontStyle=1;fontSize=12;fontColor=#7A2E2A;" vertex="1" parent="1"><mxGeometry x="765" y="190" width="650" height="66" as="geometry"/></mxCell>
    <mxCell id="p_claude" value="Claude Code&#10;runs inside the tmux 'claude' session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE0DE;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#7A2E2A;" vertex="1" parent="1"><mxGeometry x="955" y="268" width="300" height="46" as="geometry"/></mxCell>

    <mxCell id="p_tailscaled" value="tailscaled&#10;joins the tailnet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;fontSize=11;" vertex="1" parent="1"><mxGeometry x="765" y="350" width="270" height="54" as="geometry"/></mxCell>
    <mxCell id="p_sshd" value="sshd  :22&#10;key-only · hardened" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;fontSize=11;" vertex="1" parent="1"><mxGeometry x="765" y="416" width="270" height="56" as="geometry"/></mxCell>
    <mxCell id="p_cloudflared" value="cloudflared (systemd)&#10;ingress → sshd :22 · code-server :8080" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;fontSize=11;" vertex="1" parent="1"><mxGeometry x="765" y="484" width="270" height="62" as="geometry"/></mxCell>
    <mxCell id="p_codeserver" value="code-server&#10;127.0.0.1:8080 · password auth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;fontSize=11;" vertex="1" parent="1"><mxGeometry x="765" y="558" width="270" height="54" as="geometry"/></mxCell>

    <mxCell id="p_notify" value="Notify hook (Claude Stop)&#10;→ ~/.notify/mac.sock (RemoteForward)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1105" y="350" width="290" height="58" as="geometry"/></mxCell>
    <mxCell id="p_vscode" value="VS Code Remote-SSH server&#10;remote extension host&#10;(code IPC-socket refresh on reconnect)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1105" y="416" width="290" height="56" as="geometry"/></mxCell>
    <mxCell id="p_op" value="op-proxy&#10;mac mode (fwd socket) / token mode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1105" y="482" width="290" height="54" as="geometry"/></mxCell>
    <mxCell id="p_updates" value="dnf-automatic (security · reboot=never)&#10;+ reboot-notify.timer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1105" y="548" width="290" height="58" as="geometry"/></mxCell>

    <mxCell id="cloud_push" value="Pushover / ntfy&#10;→ iPhone" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1455" y="348" width="100" height="62" as="geometry"/></mxCell>

    <mxCell id="z_secrets" value="SECRETS&#10;1Password (laptop, TouchID) → resolve locally (op read / op run) → run-remote.sh streams scripts over SSH via stdin. Secrets never touch the VM disk or ps; SSH agent forwarded so keys stay TouchID-gated on the laptop." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontSize=11;fontColor=#5A4500;" vertex="1" parent="1"><mxGeometry x="40" y="800" width="620" height="100" as="geometry"/></mxCell>
    <mxCell id="z_legend" value="LEGEND&#10;━━  green solid  —  Tailscale (primary)&#10;━━  orange  —  Cloudflare (secondary)&#10;╌╌  gray dashed  —  notify / control channel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontSize=11;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="690" y="800" width="360" height="100" as="geometry"/></mxCell>
    <mxCell id="t_secrets_note" value="secrets resolved on the laptop (TouchID), then pushed to the VM" style="text;html=1;align=left;fontSize=9;fontColor=#5A4500;labelBackgroundColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="66" y="702" width="250" height="30" as="geometry"/></mxCell>

