    <mxCell id="e_cfd_tunnel" value="outbound :443" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;labelBackgroundColor=#FFFFFF;strokeColor=#D79B00;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p_cloudflared" target="t_cf_tunnel"><mxGeometry relative="1" as="geometry"/></mxCell>

